# Supabase — created once at supabase.com (free tier).
# Settings → API → Project URL and anon key.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...

# Service role key — Settings → API → service_role secret.
# NEVER commit this to git. Used only in server-side code for admin operations.
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...

# Optional — PetPooja credentials so the app can call PetPooja's API directly
# instead of requiring an Excel upload. Phase-2 feature.
PETPOOJA_EMAIL=eurokidsjmdenclave@gmail.com
PETPOOJA_BEARER_TOKEN=
